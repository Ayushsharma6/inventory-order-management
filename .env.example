# Copy this file to .env before running Docker Compose.
# Use your own strong password. Do not commit real secrets to Git.
POSTGRES_DB=inventory_db
POSTGRES_USER=inventory_app
POSTGRES_PASSWORD=replace-with-a-strong-password

# Docker Compose backend connection string. Keep this aligned with the database values above.
DATABASE_URL=postgresql://inventory_app:replace-with-a-strong-password@postgres:5432/inventory_db

# Browser-facing backend URL for the React build.
VITE_API_URL=http://localhost:8000

# Comma-separated frontend origins allowed by the backend.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Optional image names for docker-compose.prod.yml after pushing images.
BACKEND_IMAGE=your-dockerhub-username/inventory-backend:latest
FRONTEND_IMAGE=your-dockerhub-username/inventory-frontend:latest
